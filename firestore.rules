rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // count_items (nested ou flat) gravam uid no documento
    function countItemWriteValid(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.productId is string
        && request.resource.data.quantity is number
        && request.resource.data.date is timestamp;
    }

    // ===== users/{userId}/... =====
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /units/{unitId} {
        allow read, write: if isOwner(userId);
      }

      match /suppliers/{supplierId} {
        allow read, write: if isOwner(userId);
      }

      match /products/{productId} {
        allow read, write: if isOwner(userId);

        // Legado: users/{uid}/products/{productId}/counts/{countId}
        match /counts/{countId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId)
            && request.resource.data.quantity is number
            && request.resource.data.date is timestamp;
          allow delete: if isOwner(userId);
        }
      }

      match /receipts/{receiptId} {
        allow read, write: if isOwner(userId);

        match /receipt_items/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }

      // users/{uid}/stock_count_sessions/{sessionId}
      match /stock_count_sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.date is timestamp;
        allow delete: if isOwner(userId);

        // users/{uid}/stock_count_sessions/{sessionId}/count_items/{itemId}
        match /count_items/{itemId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId) && countItemWriteValid(userId);
          allow delete: if isOwner(userId);
        }
      }

      // Flat (compatibilidade): users/{uid}/stock_count_items/{itemId}
      match /stock_count_items/{itemId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && countItemWriteValid(userId)
          && request.resource.data.sessionId is string;
        allow delete: if isOwner(userId);
      }
    }

    // collectionGroup('count_items') — somente leitura do próprio usuário
    match /{path=**}/count_items/{itemId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Avaliações
    match /ratings/{ratingId} {
      allow read, write: if isSignedIn();
    }
  }
}
